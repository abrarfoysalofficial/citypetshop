# PostgreSQL Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/citypluspetshop

# NextAuth Secret (required for auth)
NEXTAUTH_SECRET=your-secret-min-32-chars-here

# NextAuth URL (required in production)
NEXTAUTH_URL=https://citypluspetshop.com

# Site URL (required for sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL=https://citypluspetshop.com

# Optional: Resend API for emails (invoices, order confirmations)
RESEND_API_KEY=re_xxxxx

# Optional: SSLCommerz Payment Gateway (set in Admin panel)
# SSLCOMMERZ_STORE_ID=your-store-id
# SSLCOMMERZ_STORE_PASSWORD=your-store-password

# Optional: Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXX
NEXT_PUBLIC_ENABLE_GTM=false

# Optional: Cloudflare Web Analytics
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
NEXT_PUBLIC_ENABLE_CF_ANALYTICS=false

# Optional: Social links
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
