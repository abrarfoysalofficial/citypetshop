# PostgreSQL Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/citypluspetshop

# NextAuth Secret (required for auth)
NEXTAUTH_SECRET=your-secret-min-32-chars-here

# NextAuth URL (http://localhost:3000 for local)
NEXTAUTH_URL=http://localhost:3000

# Site URL (required for sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin seed (optional)
ADMIN_EMAIL=admin@citypetshop.bd
ADMIN_PASSWORD=Admin@12345!

# Email (order confirmation)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@citypetshop.bd

# SMS (optional — track order OTP, order status)
BULK_SMS_BD_API_KEY=
BULK_SMS_BD_SENDER_ID=CityPlus
# Or Twilio: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM

# Secure Config (Admin Integrations)
MASTER_SECRET=

# Redis (optional — rate limiting)
REDIS_URL=

# SSLCommerz (optional — set in Admin panel)
# SSLCOMMERZ_STORE_ID=
# SSLCOMMERZ_STORE_PASSWORD=

# Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXX
NEXT_PUBLIC_ENABLE_GTM=false
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Social links
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
