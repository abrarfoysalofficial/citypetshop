# Data source: "local" (default) = demo seed data, no DB | "supabase" = use Supabase
NEXT_PUBLIC_DATA_SOURCE=local

# Auth mode: "demo" (default) = localhost demo login | "supabase" = Supabase auth
# Demo credentials only shown when NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true (admin@cityplus.local / Admin@12345, user@cityplus.local / User@12345)
NEXT_PUBLIC_AUTH_MODE=demo
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# Auth providers (when AUTH_MODE=supabase): set true/false to enable/disable
# NEXT_PUBLIC_AUTH_GOOGLE=true
# NEXT_PUBLIC_AUTH_FACEBOOK=true
# NEXT_PUBLIC_AUTH_PHONE=true

# Supabase (required when NEXT_PUBLIC_DATA_SOURCE=supabase; Admin Auth, Orders, CMS, Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Site URL for sitemap, canonical, OG
NEXT_PUBLIC_SITE_URL=https://citypluspetshop.com

# Google Tag Manager (set NEXT_PUBLIC_ENABLE_GTM=true to load)
NEXT_PUBLIC_GTM_ID=GTM-XXXX
NEXT_PUBLIC_ENABLE_GTM=false

# Cloudflare Web Analytics (privacy-first, no cookies)
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
NEXT_PUBLIC_ENABLE_CF_ANALYTICS=false

# Social links (used in footer/header; leave empty to hide)
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=

# Optional: Resend (email – invoices, order confirmation)
RESEND_API_KEY=re_xxxxx

# Optional: SMTP (alternative to Resend – set in Admin)
# SMTP_HOST=...
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...

# Optional: Meta Pixel / CAPI (set in Admin; sensitive token can use env)
# META_PIXEL_ID=...
# META_CAPI_ACCESS_TOKEN=...

# Sanity.io (required when NEXT_PUBLIC_DATA_SOURCE=sanity; CMS for products, categories, site settings)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: token for draft/preview (server-only)
# SANITY_API_READ_TOKEN=...
# Optional: webhook secret for /api/revalidate (recommended in production)
# SANITY_REVALIDATE_SECRET=your-secret
