# Production / Vercel – 3-source architecture
# Copy to Vercel Environment Variables (do not commit real values).

# --- Required in production ---
NEXT_PUBLIC_SITE_URL=https://citypetshopbd.com/

# --- 3-source config ---
# Products: sanity | local | auto
NEXT_PUBLIC_PRODUCTS_SOURCE=auto
# Auth (and orders): supabase | demo | auto
NEXT_PUBLIC_AUTH_SOURCE=auto
NEXT_PUBLIC_ENABLE_FALLBACKS=true

