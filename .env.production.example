# ═══════════════════════════════════════════════════════════════════════════════
# City Pet Shop BD — Production Environment Variables
# Copy this to .env.production.local and fill in real values.
# NEVER commit .env.production.local to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://citypetshop.bd
APP_URL=https://citypetshop.bd

# ── Redis (optional — rate limiting; fallback to in-memory if unset) ───────────
# REDIS_URL=redis://127.0.0.1:6379

# ── Secure Config (REQUIRED for Integrations — encrypted secrets at rest) ──────
# Generate with: openssl rand -hex 32
MASTER_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Use 127.0.0.1 (not localhost) for TCP connection on same host
DATABASE_URL=postgresql://cityplus_app:CHANGE_ME@127.0.0.1:5432/cityplus_db

# ── NextAuth ──────────────────────────────────────────────────────────────────
# REQUIRED: Static value. Generate with: openssl rand -hex 32
# Do NOT use $(...) or command substitution — use the literal hex string
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_hex_32
# REQUIRED: Must match your public site URL. Never use localhost in production.
NEXTAUTH_URL=https://citypetshop.bd
# REQUIRED behind proxy (Cloudflare/OpenLiteSpeed): NextAuth trusts X-Forwarded-* headers
AUTH_TRUST_HOST=true

# ── File Uploads (local filesystem) ──────────────────────────────────────────
# Absolute path on VPS where uploaded files will be stored
UPLOAD_DIR=/var/www/cityplus/uploads

# ── Payments ──────────────────────────────────────────────────────────────────
# SSLCommerz
SSLCOMMERZ_STORE_ID=your_store_id_here
SSLCOMMERZ_STORE_PASSWORD=your_store_password_here
SSLCOMMERZ_IS_LIVE=true
# Optional: Comma-separated IPs for webhook (if set, only these IPs allowed)
# SSLCOMMERZ_IP_ALLOWLIST=1.2.3.4,5.6.7.8

# ── Email Notifications (Resend) ──────────────────────────────────────────────
# Get API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@citypetshop.bd

# ── SMS Notifications ─────────────────────────────────────────────────────────
# Option 1: BulkSMSBD (Bangladesh) — preferred for BD numbers
BULK_SMS_BD_API_KEY=your_bulksmsbd_api_key
BULK_SMS_BD_SENDER_ID=CityPlus

# Option 2: Twilio (international) — uses TWILIO_* vars
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1XXXXXXXXXX

# Support contact for order notification messages
NEXT_PUBLIC_SUPPORT_PHONE=01XXXXXXXXX
NEXT_PUBLIC_SUPPORT_EMAIL=support@citypetshop.bd

# ── Analytics (optional — configure in Admin UI after deploy) ─────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ── Courier Providers (optional — add when keys available) ────────────────────
# Steadfast
# STEADFAST_API_KEY=your_steadfast_api_key
# STEADFAST_API_SECRET=your_steadfast_secret

# Pathao
# PATHAO_CLIENT_ID=your_client_id
# PATHAO_CLIENT_SECRET=your_client_secret
# PATHAO_USERNAME=your_username
# PATHAO_PASSWORD=your_password

# RedX
# REDX_API_TOKEN=your_redx_token

# ── Optional: MinIO/S3 object storage (use instead of local filesystem) ───────
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=store-assets
# MINIO_REGION=us-east-1
# MINIO_PUBLIC_URL=https://www.citypetshop.bd

# ── Optional: AI Chat (leave blank to disable) ────────────────────────────────
# OPENAI_API_KEY=sk-xxxx
# AI_MODEL=gpt-4o-mini

# ── PR-9 Security (optional) ──────────────────────────────────────────────────
# Set true to restore unsafe-eval in CSP (rollback if GTM/GA break)
# CSP_ALLOW_UNSAFE_EVAL=false
# Max body for bulk import in bytes (default 2MB, max 10MB)
# IMPORT_BODY_LIMIT_BYTES=2097152
