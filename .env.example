# =============================================================================
# City Pet Shop BD — Environment Variables
# Copy to .env: cp .env.example .env
# Required for: npm run db:setup && npm run dev
# =============================================================================

# PostgreSQL Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/citypluspetshop

# Clerk auth (required for auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key

# Site URL (required for sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Initial admin bootstrap (used by db:seed — create first admin on deploy)
# Production: set INITIAL_ADMIN_* or ADMIN_* with strong password (min 12 chars)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMeStrongPassword123!
INITIAL_ADMIN_NAME=Admin
# Legacy aliases (fallback if INITIAL_* not set)
ADMIN_EMAIL=admin@citypetshop.bd
ADMIN_PASSWORD=Admin@12345!

# Email (order confirmation)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@citypetshop.bd

# SMS (optional — track order OTP, order status)
BULK_SMS_BD_API_KEY=
BULK_SMS_BD_SENDER_ID=CityPetShop
# Or Twilio:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1234567890

# Upload storage (required for production — must be persistent across deploys)
# Local dev: defaults to ./uploads. Production: set to absolute path, e.g. /var/www/cityplus/uploads
UPLOAD_DIR=

# Secure Config (required for Admin Integrations — courier, SSLCommerz)
MASTER_SECRET=

# Redis (optional — rate limiting; in-memory fallback if not set)
REDIS_URL=

# Payment (optional — set in Admin panel or here)
# SSLCOMMERZ_STORE_ID=
# SSLCOMMERZ_STORE_PASSWORD=

# Analytics & Tracking (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ENABLE_GTM=false
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Payment toggles (configure in Admin panel)
# COD enabled by default; SSLCommerz, bKash, Nagad, Rocket via Admin

# Social links (optional)
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
NEXT_PUBLIC_SUPPORT_PHONE=01643390045
NEXT_PUBLIC_SUPPORT_EMAIL=support@citypetshop.bd
